# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tax_optimizer_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_secret

# ─── AI (Groq or OpenAI) ──────────────────────────────────────────────────────
# Groq key starts with gsk_ — OpenAI key starts with sk-
AI_API_KEY=your_groq_or_openai_key_here
