# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_SECRET=change_me_to_a_long_random_string

# ─── Account Aggregator ────────────────────────────────────────────────────────
AA_BASE_URL=https://api.setu.co/v2
AA_CLIENT_ID=your_aa_client_id
AA_CLIENT_SECRET=your_aa_client_secret

# AA key pair (PEM, base64-encoded for env safety)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then: base64 -w 0 private.pem  →  paste here
AA_PRIVATE_KEY_B64=base64_encoded_pem_private_key
AA_PUBLIC_KEY_B64=base64_encoded_pem_public_key

# AA provider webhook secret for HMAC verification
AA_WEBHOOK_SECRET=your_webhook_hmac_secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aa_taxharvest?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Encryption (AES-256 for tokens at rest) ──────────────────────────────────
ENCRYPTION_KEY=32_char_hex_key_here_change_me!!

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
